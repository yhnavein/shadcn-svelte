{
  "name": "@puredev/shadcn-svelte-tw",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run prepack",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./theme.css": "./dist/theme.css"
  },
  "peerDependencies": {
    "svelte": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "tw-animate-css": "^1.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "2.0.2",
    "@eslint/js": "10.0.1",
    "@internationalized/date": "^3.10.0",
    "@lucide/svelte": "^0.561.0",
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/table-core": "^8.21.3",
    "bits-ui": "^2.14.4",
    "clsx": "^2.1.1",
    "embla-carousel-svelte": "^8.6.0",
    "formsnap": "^2.0.1",
    "layerchart": "2.0.0-next.43",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "publint": "^0.3.17",
    "svelte": "^5.49.2",
    "svelte-check": "^4.3.6",
    "svelte-sonner": "^1.0.7",
    "sveltekit-superforms": "^2.28.1",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "vaul-svelte": "^1.0.0-next.7",
    "vite": "^7.3.1"
  },
  "author": "PureDev <admin@puredev.eu>",
  "description": "A Shadcn Svelte component library built for simple and easy use in SvelteKit projects.",
  "keywords": [
    "shadcn",
    "svelte",
    "tailwind",
    "SvelteKit",
    "component library"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/puredev/shadcn"
  },
  "bugs": {
    "url": "https://github.com/puredev/shadcn/issues"
  },
  "homepage": "https://github.com/puredev/shadcn"
}
